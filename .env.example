# Copy to .env and fill in real values. NEVER commit .env (it is gitignored).
# Prefer short-lived credentials (AWS SSO / an assumed role) over static keys.

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Slack incoming webhook for pipeline alerts. For production, store this in AWS
# Secrets Manager / SSM SecureString rather than a local file — see README.md §6.
SLACK_APP_WEBHOOK_URL=

# Glue scripts bucket — value of: terraform -chdir=terraform output -raw scripts_bucket_name
SCRIPTS_BUCKET=

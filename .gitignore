# ── Secrets and credentials (NEVER commit — use the *.example templates) ─────
.env
*.tfvars
!*.tfvars.example

# ── Terraform state (may contain secrets — NEVER commit, any directory) ──────
*.tfstate
*.tfstate.*
*.tfplan

# ── Terraform local provider cache ────────────────────────────────────────────
# .terraform.lock.hcl IS committed on purpose (pins provider hashes for
# reproducible CI/Docker builds) — do not add it here.
.terraform/

# ── Build artefacts (regenerated by Terraform archive_file at apply time) ─────
/glue_jobs.zip
/slack_notifier.zip

# ── Project data files (sample inputs live outside version control) ───────────
Data/
data/
*.xlsx
*.docx
*.pptx

# ── Python ────────────────────────────────────────────────────────────────────
venv/
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.coverage
htmlcov/
